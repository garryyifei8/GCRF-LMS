# ============================================
# GCRF Library Management System
# Environment Configuration Template
# ============================================
#
# INSTRUCTIONS:
# 1. Copy this file to .env for local development
# 2. Copy to .env.prod for production (store securely, not in git)
# 3. Replace ALL placeholder values with actual secrets
# 4. NEVER commit .env or .env.prod to version control
#
# SECURITY NOTES:
# - All passwords should be at least 32 characters
# - Use different credentials for each environment
# - Rotate all secrets every 90 days
# - Use a secrets manager in production (Vault, AWS Secrets Manager)
#
# ============================================

# ============================================
# Environment Settings
# ============================================
# Options: dev, staging, prod
SPRING_PROFILES_ACTIVE=dev

# Deployment environment name
ENVIRONMENT=development

# ============================================
# JWT Configuration
# ============================================
# CRITICAL: Generate a strong secret with:
#   openssl rand -base64 64
#
# Requirements:
# - Minimum 64 characters (512 bits for HS512)
# - Cryptographically random
# - Unique per environment

JWT_SECRET=REPLACE_WITH_RANDOM_64_CHARACTER_SECRET_GENERATED_WITH_OPENSSL_RAND_BASE64_64

# Access token expiration in milliseconds
# Default: 1800000 (30 minutes) for production
# Development: 86400000 (24 hours) for convenience
JWT_EXPIRATION=1800000

# Refresh token expiration in milliseconds
# Default: 604800000 (7 days)
JWT_REFRESH_EXPIRATION=604800000

# Token issuer identifier
JWT_ISSUER=GCRF-Library-System

# ============================================
# PostgreSQL Database Configuration
# ============================================
# SECURITY: Use a dedicated user with minimal privileges
#
# Generate password with:
#   openssl rand -base64 32

# Primary database connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gcrf_auth

# Database credentials
# IMPORTANT: Do not use 'postgres' superuser in production
DB_USERNAME=gcrf_app
DB_PASSWORD=REPLACE_WITH_32_CHAR_DATABASE_PASSWORD

# Connection pool settings
DB_POOL_SIZE=10
DB_POOL_MAX_SIZE=20

# SSL Mode (disable for dev, require for prod)
# Options: disable, allow, prefer, require, verify-ca, verify-full
DB_SSL_MODE=disable

# Full JDBC URL (optional, overrides individual settings)
# DB_URL=jdbc:postgresql://localhost:5432/gcrf_auth?sslmode=require

# ============================================
# Redis Configuration
# ============================================
# Generate password with:
#   openssl rand -base64 32

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_32_CHAR_REDIS_PASSWORD
REDIS_DATABASE=0

# Redis Sentinel configuration (for HA)
# REDIS_SENTINEL_MASTER=mymaster
# REDIS_SENTINEL_NODES=sentinel1:26379,sentinel2:26379,sentinel3:26379

# TLS for Redis (enable in production)
# REDIS_SSL_ENABLED=true

# ============================================
# RabbitMQ Configuration
# ============================================
# Generate password with:
#   openssl rand -base64 32

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=gcrf_app
RABBITMQ_PASSWORD=REPLACE_WITH_32_CHAR_RABBITMQ_PASSWORD
RABBITMQ_VHOST=/gcrf

# Management port (for monitoring)
RABBITMQ_MANAGEMENT_PORT=15672

# ============================================
# MinIO Object Storage Configuration
# ============================================
# Generate keys with:
#   Access Key: openssl rand -hex 16
#   Secret Key: openssl rand -base64 32

MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=REPLACE_WITH_32_CHAR_ACCESS_KEY
MINIO_SECRET_KEY=REPLACE_WITH_32_CHAR_SECRET_KEY
MINIO_BUCKET_NAME=gcrf-library

# MinIO Region (optional)
MINIO_REGION=us-east-1

# Use secure connection (HTTPS)
MINIO_SECURE=false

# ============================================
# Nacos Service Discovery Configuration
# ============================================
# IMPORTANT: Change default credentials!

NACOS_SERVER_ADDR=localhost:8848
NACOS_USERNAME=gcrf_nacos
NACOS_PASSWORD=REPLACE_WITH_32_CHAR_NACOS_PASSWORD
NACOS_NAMESPACE=public
NACOS_GROUP=DEFAULT_GROUP

# ============================================
# Elasticsearch Configuration (Optional)
# ============================================

ELASTICSEARCH_URIS=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=REPLACE_WITH_ELASTICSEARCH_PASSWORD

# ============================================
# CORS Configuration
# ============================================
# CRITICAL: Specify exact domains in production
# Never use * in production

# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3011,http://localhost:5173

# For production, use actual domains:
# CORS_ALLOWED_ORIGINS=https://library.gcrf.com,https://admin.gcrf.com

# ============================================
# Server Configuration
# ============================================

# Gateway service port
GATEWAY_PORT=8080

# Management/actuator port (recommended: separate from main port)
MANAGEMENT_PORT=8090

# Server thread configuration
SERVER_IO_THREADS=8
SERVER_WORKER_THREADS=200

# ============================================
# Logging Configuration
# ============================================

# Log level for application code
# Options: TRACE, DEBUG, INFO, WARN, ERROR
# IMPORTANT: Use INFO or WARN in production (never DEBUG)
LOG_LEVEL=INFO

# Log file location
LOG_PATH=/var/log/gcrf

# Log retention days
LOG_RETENTION_DAYS=30

# ============================================
# Security Configuration
# ============================================

# BCrypt password encoder strength (4-31, higher = slower but more secure)
BCRYPT_STRENGTH=12

# Account lockout settings
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# ============================================
# Rate Limiting Configuration
# ============================================

# Global rate limit (requests per minute per IP)
RATE_LIMIT_GLOBAL=100

# Authentication rate limit (requests per minute per IP)
RATE_LIMIT_AUTH=10

# ============================================
# Monitoring Configuration
# ============================================

# Prometheus metrics endpoint
METRICS_ENABLED=true

# Health check endpoint
HEALTH_CHECK_PATH=/actuator/health

# ============================================
# Email/SMTP Configuration (Optional)
# ============================================

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=noreply@gcrf.com
# SMTP_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
# SMTP_FROM=noreply@gcrf.com

# ============================================
# External API Keys (if applicable)
# ============================================

# AI Service API Key (for chat service)
# OPENAI_API_KEY=sk-REPLACE_WITH_API_KEY

# SMS Service API Key
# SMS_API_KEY=REPLACE_WITH_SMS_API_KEY

# ============================================
# IMPORTANT REMINDERS
# ============================================
#
# Before Production Deployment:
#
# [ ] All REPLACE_WITH_* placeholders have been replaced
# [ ] All passwords are unique and strong (32+ chars)
# [ ] JWT_SECRET is 64+ characters
# [ ] CORS_ALLOWED_ORIGINS specifies exact domains
# [ ] LOG_LEVEL is set to INFO or WARN
# [ ] DB_SSL_MODE is set to require
# [ ] BCRYPT_STRENGTH is at least 10
# [ ] This file is NOT committed to version control
# [ ] Secrets are stored in a secure vault
# [ ] Access to this file is restricted
#
# ============================================
