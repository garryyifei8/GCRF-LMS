            <div class="metric">
                <span class="metric-name">Database:</span>
                <span class="metric-value">{{ .Labels.datname }}</span>
            </div>
            <div class="metric">
                <span class="metric-name">Instance:</span>
                <span class="metric-value">{{ .Labels.instance }}</span>
            </div>
            {{ end }}
        </div>
    </div>
</body>
</html>
{{ end }}

