{{/* ========================================
     Database Alert Email Template
     ======================================== */}}
{{ define "email.database.html" }}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body {
            font-family: monospace;
            line-height: 1.6;
            color: #333;
            max-width: 800px;
            margin: 0 auto;
            padding: 20px;
        }
        .container {
            background-color: #1e1e1e;
            color: #d4d4d4;
            border-radius: 8px;
            overflow: hidden;
        }
        .header {
            background-color: #0078d4;
            color: white;
            padding: 15px 20px;
        }
        .content {
            padding: 20px;
        }
        .metric {
            background-color: #2d2d2d;
            padding: 10px 15px;
            margin: 10px 0;
            border-radius: 4px;
        }
        .metric-name {
            color: #569cd6;
        }
        .metric-value {
            color: #ce9178;
        }
