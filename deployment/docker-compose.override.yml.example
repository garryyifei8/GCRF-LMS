# ============================================
# GCRF Library Management System
# Development Override Configuration
# ============================================
# This file provides development-friendly overrides for local development
# Copy to docker-compose.override.yml to use (auto-loaded by docker-compose)
#
# Usage:
#   cp docker-compose.override.yml.example docker-compose.override.yml
#   docker-compose up -d  # Will automatically use overrides
# ============================================

version: '3.8'

services:
  # ============================================
  # PostgreSQL - Development Configuration
  # ============================================
  postgres-primary:
    # Expose PostgreSQL to host for direct access
    ports:
      - "5432:5432"
    environment:
      # Simple password for development
      POSTGRES_PASSWORD: gcrf_dev_2024
      # Enable statement logging for debugging
      POSTGRES_INITDB_ARGS: "-E UTF8 --locale=en_US.UTF-8"
    # More verbose logging
    command: >
      postgres
      -c log_statement=all
      -c log_duration=on
      -c log_connections=on
      -c log_disconnections=on
      -c shared_preload_libraries='pg_stat_statements'

  # ============================================
  # Redis - Development Configuration
  # ============================================
  redis-master:
    # Expose Redis to host
    ports:
      - "6379:6379"
    # Simplified configuration for development
    command: >
      redis-server
      --requirepass gcrf_redis_dev
      --loglevel debug
      --save 60 1
      --appendonly no
    # Mount redis config for easy modification
    volumes:
      - redis-master-data:/data
      - ./redis/redis.conf:/usr/local/etc/redis/redis.conf:ro

  # ============================================
  # Nacos - Development Configuration
  # ============================================
  nacos-mysql:
    # Expose MySQL for debugging
    ports:
      - "3306:3306"
    environment:
      MYSQL_ROOT_PASSWORD: nacos_mysql_dev
      MYSQL_PASSWORD: nacos_dev

  nacos:
    # Expose all ports to host
    ports:
      - "8848:8848"  # HTTP API
      - "9848:9848"  # gRPC
      - "9849:9849"  # Raft port (for future clustering)
    environment:
      # Simpler authentication for development
      NACOS_AUTH_ENABLE: "false"  # Disable auth for easier development
      # Or use simple dev credentials
      # NACOS_AUTH_ENABLE: "true"
      # NACOS_USERNAME: nacos
      # NACOS_PASSWORD: nacos
      # Debug logging
      JVM_XMS: 256m
      JVM_XMX: 256m
      NACOS_DEBUG: "true"
      # Embedded storage for simplicity (no MySQL needed)
      # Uncomment to use embedded storage instead of MySQL
      # SPRING_DATASOURCE_PLATFORM: embedded
      # MODE: standalone

  # ============================================
  # RabbitMQ - Development Configuration
  # ============================================
  rabbitmq:
    # Expose all ports
    ports:
      - "5672:5672"   # AMQP
      - "15672:15672" # Management UI
      - "25672:25672" # Clustering
    environment:
      RABBITMQ_DEFAULT_USER: admin
      RABBITMQ_DEFAULT_PASS: admin
      # Enable all management plugins
      RABBITMQ_PLUGINS: "rabbitmq_management rabbitmq_management_agent rabbitmq_prometheus rabbitmq_shovel rabbitmq_shovel_management"
    # Mount custom configuration
    volumes:
      - rabbitmq-data:/var/lib/rabbitmq
      - ./rabbitmq/enabled_plugins:/etc/rabbitmq/enabled_plugins:ro
      - ./rabbitmq/rabbitmq.conf:/etc/rabbitmq/rabbitmq.conf:ro

  # ============================================
  # MinIO - Development Configuration
  # ============================================
  minio:
    # Expose all ports to host
    ports:
      - "9000:9000"  # S3 API
      - "9001:9001"  # Console
    environment:
      MINIO_ROOT_USER: minioadmin
      MINIO_ROOT_PASSWORD: minioadmin
      # Development buckets auto-creation
      MINIO_DEFAULT_BUCKETS: "gcrf-documents,gcrf-images,gcrf-backups"
      # Enable browser
      MINIO_BROWSER: "on"
      # Console configuration
      MINIO_CONSOLE_PORT_NUMBER: 9001
    # Mount local directory for easy access
    volumes:
      - minio-data:/data
      - ./minio/policies:/policies:ro

# ============================================
# Additional Development Services
# ============================================
# Uncomment to add development-only services

  # # Adminer - Database management UI
  # adminer:
