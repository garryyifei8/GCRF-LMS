  #     com.gcrf.service: "dev-tool"
  #     com.gcrf.tier: "development"

# ============================================
# Volume Overrides for Development
# ============================================
volumes:
  # Use local directories for easier debugging
  postgres-primary-data:
    driver: local
    driver_opts:
      type: none
      device: ${PWD}/data/postgres
      o: bind

  redis-master-data:
    driver: local
    driver_opts:
      type: none
      device: ${PWD}/data/redis
      o: bind

  minio-data:
    driver: local
    driver_opts:
      type: none
      device: ${PWD}/data/minio
      o: bind