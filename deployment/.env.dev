# GCRF Dev Environment — offset ports to coexist with edu-dev
# Usage: docker compose --env-file .env.dev -f docker-compose.infrastructure.yml up -d

SPRING_PROFILES_ACTIVE=dev
ENVIRONMENT=development

# JWT
JWT_SECRET=dev-secret-gcrf-library-management-system-jwt-key-2026
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000
JWT_ISSUER=GCRF-Library-System

# PostgreSQL — HOST port 25432 (internal 5432)
DB_HOST=localhost
DB_PORT=25432
DB_NAME=gcrf_auth
DB_USERNAME=postgres
DB_PASSWORD=gcrf_dev_2026
DB_POOL_SIZE=5
DB_POOL_MAX_SIZE=10
DB_SSL_MODE=disable

# Redis — HOST port 26379 (internal 6379)
REDIS_HOST=localhost
REDIS_PORT=26379
REDIS_PASSWORD=gcrf_redis_dev
REDIS_DATABASE=0

# Nacos — HOST port 28848 (internal 8848)
NACOS_HOST=localhost
NACOS_PORT=28848
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos
NACOS_NAMESPACE=

# RabbitMQ — HOST ports 25672/35672
RABBITMQ_HOST=localhost
RABBITMQ_PORT=25672
RABBITMQ_MANAGEMENT_PORT=35672
RABBITMQ_USERNAME=gcrf_mq
RABBITMQ_PASSWORD=gcrf_mq_dev
RABBITMQ_VHOST=/gcrf

# MinIO — HOST ports 29000/29001
MINIO_HOST=localhost
MINIO_PORT=29000
MINIO_CONSOLE_PORT=29001
MINIO_ROOT_USER=gcrf_minio_admin
MINIO_ROOT_PASSWORD=gcrf_minio_dev_2026
MINIO_BUCKET=library-files
