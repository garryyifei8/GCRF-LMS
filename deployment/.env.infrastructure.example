# ============================================
# GCRF Library Management System
# Infrastructure Environment Configuration
# ============================================
# This file contains additional infrastructure-specific configurations
# that extend the main .env.prod.example file
# ============================================

# ============================================
# Nacos MySQL Backend Configuration
# ============================================
# Root password for Nacos MySQL instance
NACOS_MYSQL_ROOT_PASSWORD=REPLACE_WITH_STRONG_ROOT_PASSWORD

# Password for nacos user (must match NACOS_MYSQL_PASSWORD)
NACOS_MYSQL_PASSWORD=REPLACE_WITH_STRONG_NACOS_PASSWORD

# Nacos authentication token (used for internal API security)
# Generate with: openssl rand -hex 32
NACOS_AUTH_TOKEN=REPLACE_WITH_RANDOM_64_CHARACTER_TOKEN

# ============================================
# RabbitMQ Configuration
# ============================================
# RabbitMQ admin username
RABBITMQ_USERNAME=gcrf_rabbitmq_admin

# RabbitMQ admin password
RABBITMQ_PASSWORD=REPLACE_WITH_STRONG_RABBITMQ_PASSWORD

# Erlang cookie for RabbitMQ clustering (future use)
# Generate with: openssl rand -hex 20
RABBITMQ_ERLANG_COOKIE=REPLACE_WITH_RANDOM_ERLANG_COOKIE

# ============================================
# MinIO Object Storage Configuration
# ============================================
# MinIO root username (min 3 characters)
MINIO_ROOT_USER=gcrf_minio_admin

# MinIO root password (min 8 characters)
MINIO_ROOT_PASSWORD=REPLACE_WITH_STRONG_MINIO_PASSWORD

# MinIO region name (for S3 compatibility)
MINIO_REGION=us-east-1

# MinIO domain for virtual host-style bucket access
MINIO_DOMAIN=minio.gcrf.local

# ============================================
# PostgreSQL Configuration
# ============================================
# Note: DB_PASSWORD is defined in main .env file
# These are additional PostgreSQL configurations

# Application database user password (if different from superuser)
DB_APP_PASSWORD=REPLACE_WITH_APP_USER_PASSWORD

# PostgreSQL replication password (for future clustering)
POSTGRES_REPLICATION_PASSWORD=REPLACE_WITH_REPLICATION_PASSWORD

# ============================================
# Infrastructure Network Configuration
# ============================================
# Docker network subnet (optional, defaults are usually fine)
# INFRASTRUCTURE_SUBNET=172.28.0.0/16

# ============================================
# Volume Backup Configuration
# ============================================
# Backup retention days
BACKUP_RETENTION_DAYS=30

# Backup storage path on host
BACKUP_PATH=/data/backups/gcrf

# ============================================
# Monitoring Configuration (Future Use)
# ============================================
# Prometheus metrics port
METRICS_PORT=9090

# Grafana admin password
GRAFANA_ADMIN_PASSWORD=REPLACE_WITH_GRAFANA_PASSWORD

# ============================================
# Security Notes for Infrastructure
# ============================================
# 1. Generate all passwords with strong randomness:
#    - Passwords: openssl rand -base64 32
#    - Tokens: openssl rand -hex 32
#    - Cookies: openssl rand -hex 20
#
# 2. Store this file securely and never commit to version control
#
# 3. Use different passwords for each environment
#
# 4. Rotate all credentials every 90 days
#
# 5. Ensure file permissions are restricted:
#    chmod 600 .env.infrastructure
#
# 6. Consider using secrets management tools like:
#    - Docker Secrets (for Swarm mode)
#    - HashiCorp Vault
#    - AWS Secrets Manager
#    - Azure Key Vault
# ============================================