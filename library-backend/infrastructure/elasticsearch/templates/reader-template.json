{
  "index_patterns": ["library-readers-*"],
  "template": {
    "settings": {
      "number_of_shards": 2,
      "number_of_replicas": 1,
      "analysis": {
        "analyzer": {
          "ik_smart_analyzer": {
            "type": "custom",
            "tokenizer": "ik_smart",
            "filter": ["lowercase"]
          },
          "ik_max_word_analyzer": {
            "type": "custom",
            "tokenizer": "ik_max_word",
            "filter": ["lowercase"]
          }
        }
      },
      "index": {
        "max_result_window": 10000,
        "refresh_interval": "1s"
      }
    },
    "mappings": {
      "properties": {
        "reader_id": {
          "type": "keyword"
        },
        "card_number": {
          "type": "keyword"
        },
        "name": {
          "type": "text",
          "analyzer": "ik_smart_analyzer",
          "fields": {
            "keyword": {
              "type": "keyword",
              "ignore_above": 256
            }
          }
        },
        "phone": {
          "type": "keyword"
        },
        "email": {
          "type": "keyword"
        },
        "gender": {
          "type": "keyword"
        },
        "age": {
          "type": "integer"
        },
        "id_number": {
          "type": "keyword"
        },
        "address": {
          "type": "text",
          "analyzer": "ik_smart_analyzer"
        },
        "reader_type": {
          "type": "keyword"
        },
        "register_date": {
          "type": "date"
        },
        "expire_date": {
          "type": "date"
        },
        "deposit": {
          "type": "scaled_float",
          "scaling_factor": 100
        },
        "balance": {
          "type": "scaled_float",
          "scaling_factor": 100
        },
        "borrow_quota": {
          "type": "integer"
        },
        "borrowed_count": {
          "type": "integer"
        },
        "total_borrow_count": {
          "type": "integer"
        },
        "overdue_count": {
          "type": "integer"
        },
        "violation_count": {
          "type": "integer"
        },
        "credit_score": {
          "type": "integer"
        },
        "status": {
          "type": "keyword"
        },
        "tags": {
          "type": "keyword"
        },
        "preferences": {
          "type": "keyword"
        },
        "avatar_url": {
          "type": "keyword",
          "index": false
        },
        "remarks": {
          "type": "text",
          "analyzer": "ik_smart_analyzer"
        },
        "created_at": {
          "type": "date"
        },
        "updated_at": {
          "type": "date"
        },
        "last_login": {
          "type": "date"
        }
      }
    }
  },
  "priority": 100,
  "version": 1,
  "_meta": {
    "description": "Template for library reader index with IK analyzer"
  }
}
