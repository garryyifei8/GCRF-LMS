# GCRF Library Management System - Environment Variables Template
# Copy this file to .env and update with your values
# DO NOT commit .env files with real credentials to version control

# ============================================================================
# GLOBAL CONFIGURATION
# ============================================================================

# Environment name (dev|staging|prod)
ENVIRONMENT=dev

# Spring profile to activate
SPRING_PROFILES_ACTIVE=dev

# Timezone for all services
TZ=Asia/Shanghai

# Log level (ERROR|WARN|INFO|DEBUG|TRACE)
LOG_LEVEL=INFO

# Application name prefix
APP_NAME_PREFIX=gcrf-library

# ============================================================================
# SERVICE DISCOVERY (Nacos)
# ============================================================================

# Nacos server address (host:port)
# Required by: all services
NACOS_SERVER_ADDR=localhost:8848

# Nacos namespace (leave empty for default)
NACOS_NAMESPACE=

# Nacos group
NACOS_GROUP=DEFAULT_GROUP

# Nacos username (if authentication enabled)
NACOS_USERNAME=nacos

# Nacos password (if authentication enabled)
NACOS_PASSWORD=nacos

# Service discovery enabled
NACOS_DISCOVERY_ENABLED=true

# Config center enabled
NACOS_CONFIG_ENABLED=true

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================

# Primary database host
DB_HOST=localhost

# Database port
DB_PORT=5432

# Database name prefix (services will append their suffix)
DB_NAME_PREFIX=gcrf

# Database username
DB_USERNAME=postgres

# Database password (SENSITIVE - use Docker secrets in production)
DB_PASSWORD=postgres123

# Connection pool settings
DB_POOL_SIZE=20
DB_POOL_MIN_IDLE=5
DB_POOL_MAX_LIFETIME=1800000
DB_CONNECTION_TIMEOUT=30000

# PostgreSQL specific settings
DB_SSL_MODE=disable
DB_SCHEMA=public

# Read replica configuration (optional)
DB_READ_REPLICA_HOST=
DB_READ_REPLICA_PORT=5432

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================

# Redis mode (standalone|sentinel|cluster)
REDIS_MODE=standalone

# Standalone configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Sentinel configuration (comma-separated list)
REDIS_SENTINEL_NODES=sentinel1:26379,sentinel2:26379,sentinel3:26379
REDIS_SENTINEL_MASTER=mymaster

# Redis password (SENSITIVE - use Docker secrets in production)
REDIS_PASSWORD=

# Redis database index
REDIS_DATABASE=0

# Connection pool settings
REDIS_POOL_MAX_ACTIVE=8
REDIS_POOL_MAX_IDLE=8
REDIS_POOL_MIN_IDLE=0
REDIS_POOL_MAX_WAIT=-1

# Redis timeout (milliseconds)
REDIS_TIMEOUT=2000

# ============================================================================
# MESSAGE QUEUE (RabbitMQ)
# ============================================================================

# RabbitMQ host
RABBITMQ_HOST=localhost

# RabbitMQ port
RABBITMQ_PORT=5672

# RabbitMQ virtual host
RABBITMQ_VHOST=/

# RabbitMQ username
RABBITMQ_USERNAME=guest

# RabbitMQ password (SENSITIVE - use Docker secrets in production)
RABBITMQ_PASSWORD=guest

# Connection settings
RABBITMQ_CONNECTION_TIMEOUT=60000
RABBITMQ_REQUESTED_HEARTBEAT=60

# ============================================================================
# OBJECT STORAGE (MinIO)
# ============================================================================

# MinIO endpoint
MINIO_ENDPOINT=http://localhost:9000

# MinIO access key (SENSITIVE)
MINIO_ACCESS_KEY=minioadmin

# MinIO secret key (SENSITIVE - use Docker secrets in production)
MINIO_SECRET_KEY=minioadmin

# MinIO bucket names
MINIO_BUCKET_BOOKS=books
MINIO_BUCKET_COVERS=book-covers
MINIO_BUCKET_DOCUMENTS=documents

# MinIO region
MINIO_REGION=us-east-1

# ============================================================================
# SECURITY (JWT & Authentication)
# ============================================================================

# JWT secret key (SENSITIVE - MUST be changed in production)
JWT_SECRET=your-256-bit-secret-key-change-this-in-production

# JWT issuer
JWT_ISSUER=gcrf-library-system

# JWT expiration times (seconds)
JWT_ACCESS_TOKEN_VALIDITY=3600
JWT_REFRESH_TOKEN_VALIDITY=86400

# BCrypt strength (4-31, higher is more secure but slower)
BCRYPT_STRENGTH=10

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3011,http://localhost:3012

# ============================================================================
# GATEWAY SERVICE (Port 8080)
# ============================================================================

# Gateway server port
GATEWAY_SERVER_PORT=8080

# Gateway routes timeout (milliseconds)
GATEWAY_TIMEOUT=30000

# Rate limiting (requests per second)
GATEWAY_RATE_LIMIT=100

# Circuit breaker threshold
GATEWAY_CIRCUIT_BREAKER_THRESHOLD=50

# Request size limit (bytes)
GATEWAY_MAX_REQUEST_SIZE=10485760

# ============================================================================
# AUTH SERVICE (Port 8081)
# ============================================================================

# Auth service port
AUTH_SERVER_PORT=8081

# Auth database name
AUTH_DB_NAME=gcrf_auth

# Session timeout (seconds)
AUTH_SESSION_TIMEOUT=1800

# Maximum login attempts
AUTH_MAX_LOGIN_ATTEMPTS=5

# Account lock duration (minutes)
AUTH_ACCOUNT_LOCK_DURATION=30

# Password policy
AUTH_PASSWORD_MIN_LENGTH=8
AUTH_PASSWORD_REQUIRE_UPPERCASE=true
AUTH_PASSWORD_REQUIRE_LOWERCASE=true
AUTH_PASSWORD_REQUIRE_NUMBERS=true
AUTH_PASSWORD_REQUIRE_SPECIAL=true

# ============================================================================
# BOOK SERVICE (Port 8082)
# ============================================================================

# Book service port
BOOK_SERVER_PORT=8082

# Book database name
BOOK_DB_NAME=gcrf_book

# ISBN validation enabled
BOOK_ISBN_VALIDATION=true

# Book cover max size (bytes)
BOOK_COVER_MAX_SIZE=5242880

# Full-text search enabled
BOOK_SEARCH_ENABLED=true

# ============================================================================
# CIRCULATION SERVICE (Port 8083)
# ============================================================================

# Circulation service port
CIRCULATION_SERVER_PORT=8083

# Circulation database name
CIRCULATION_DB_NAME=gcrf_circulation

# Default loan period (days)
CIRCULATION_LOAN_PERIOD=30

# Maximum renewals
CIRCULATION_MAX_RENEWALS=2

# Fine per day (in cents)
CIRCULATION_FINE_PER_DAY=50

# Reservation expiry (hours)
CIRCULATION_RESERVATION_EXPIRY=48

# ============================================================================
# READER SERVICE (Port 8084)
# ============================================================================

# Reader service port
READER_SERVER_PORT=8084

# Reader database name
READER_DB_NAME=gcrf_reader

# Reader card prefix
READER_CARD_PREFIX=GCRF

# Maximum books per reader
READER_MAX_BOOKS=10

# Reader types (comma-separated)
READER_TYPES=STUDENT,TEACHER,EXTERNAL

# ============================================================================
# SYSTEM SERVICE (Port 8085)
# ============================================================================

# System service port
SYSTEM_SERVER_PORT=8085

# System database name
SYSTEM_DB_NAME=gcrf_system

# Audit log enabled
SYSTEM_AUDIT_ENABLED=true

# Metrics collection interval (seconds)
SYSTEM_METRICS_INTERVAL=60

# Backup schedule (cron expression)
SYSTEM_BACKUP_SCHEDULE=0 2 * * *

# ============================================================================
# NOTIFICATION SERVICE (Port 8086)
# ============================================================================

# Notification service port
NOTIFICATION_SERVER_PORT=8086

# Notification database name
NOTIFICATION_DB_NAME=gcrf_notification

# Email configuration
NOTIFICATION_SMTP_HOST=smtp.example.com
NOTIFICATION_SMTP_PORT=587
NOTIFICATION_SMTP_USERNAME=notifications@gcrf.com
NOTIFICATION_SMTP_PASSWORD=
NOTIFICATION_SMTP_FROM=GCRF Library <no-reply@gcrf.com>

# SMS configuration (optional)
NOTIFICATION_SMS_ENABLED=false
NOTIFICATION_SMS_PROVIDER=
NOTIFICATION_SMS_API_KEY=

# WeChat configuration (optional)
NOTIFICATION_WECHAT_ENABLED=false
NOTIFICATION_WECHAT_APP_ID=
NOTIFICATION_WECHAT_APP_SECRET=

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================

# Prometheus metrics enabled
METRICS_ENABLED=true
METRICS_PORT=9090

# Tracing enabled (OpenTelemetry)
TRACING_ENABLED=true
TRACING_ENDPOINT=http://localhost:4317

# Health check intervals (seconds)
HEALTH_CHECK_INTERVAL=30

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================

# JVM heap size
JVM_XMS=512m
JVM_XMX=2g

# Tomcat threads
SERVER_TOMCAT_THREADS_MAX=200
SERVER_TOMCAT_THREADS_MIN=10

# Hikari connection pool
HIKARI_MAXIMUM_POOL_SIZE=20
HIKARI_MINIMUM_IDLE=5

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Feature toggles
FEATURE_NEW_UI_ENABLED=false
FEATURE_ADVANCED_SEARCH=true
FEATURE_SOCIAL_LOGIN=false
FEATURE_MOBILE_APP=false
FEATURE_AI_RECOMMENDATIONS=false

# ============================================================================
# DEPLOYMENT CONFIGURATION
# ============================================================================

# Docker registry
DOCKER_REGISTRY=registry.gcrf.com

# Image tag
IMAGE_TAG=latest

# Deployment namespace
DEPLOY_NAMESPACE=gcrf-library

# Resource limits
RESOURCE_LIMIT_CPU=1000m
RESOURCE_LIMIT_MEMORY=2Gi
RESOURCE_REQUEST_CPU=500m
RESOURCE_REQUEST_MEMORY=1Gi