# ====================================================================
# PostgreSQL 环境变量配置文件
# 用途: 配置数据库集群的连接信息和认证凭据
# 使用方法: 复制此文件为 .env 并修改相应的密码
# ====================================================================

# ----------------------------------------------------------------
# PostgreSQL 主库配置
# ----------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=gcrf_secure_2024

# ----------------------------------------------------------------
# 复制用户配置
# ----------------------------------------------------------------
REPLICATION_USER=replicator
REPLICATION_PASSWORD=repl_secure_2024

# ----------------------------------------------------------------
# Patroni 高可用配置（可选）
# ----------------------------------------------------------------
PATRONI_ADMIN_PASSWORD=admin_secure_2024

# ----------------------------------------------------------------
# 微服务数据库用户密码
# ----------------------------------------------------------------
AUTH_USER_PASSWORD=auth_pass_2024
BOOK_USER_PASSWORD=book_pass_2024
READER_USER_PASSWORD=reader_pass_2024
CIRCULATION_USER_PASSWORD=circulation_pass_2024
SYSTEM_USER_PASSWORD=system_pass_2024
RECOMMEND_USER_PASSWORD=recommend_pass_2024
NLP_USER_PASSWORD=nlp_pass_2024
VISION_USER_PASSWORD=vision_pass_2024
ANALYTICS_USER_PASSWORD=analytics_pass_2024
NOTIFICATION_USER_PASSWORD=notification_pass_2024
FILE_USER_PASSWORD=file_pass_2024
SEARCH_USER_PASSWORD=search_pass_2024

# ----------------------------------------------------------------
# 网络配置
# ----------------------------------------------------------------
PRIMARY_HOST=postgres-primary
PRIMARY_PORT=5432
REPLICA1_PORT=5433
REPLICA2_PORT=5434
PGBOUNCER_PORT=6432

# ----------------------------------------------------------------
# 性能配置
# ----------------------------------------------------------------
MAX_CONNECTIONS=200
SHARED_BUFFERS=256MB
EFFECTIVE_CACHE_SIZE=1GB
WORK_MEM=4MB
MAINTENANCE_WORK_MEM=64MB

# ----------------------------------------------------------------
# 备份配置
# ----------------------------------------------------------------
BACKUP_RETENTION_DAYS=30
BACKUP_DIR=/backup

# ----------------------------------------------------------------
# 生产环境安全建议
# ----------------------------------------------------------------
# 1. 使用强密码（至少16个字符，包含大小写字母、数字和特殊字符）
# 2. 定期更换密码（建议每90天更换一次）
# 3. 不要将此文件提交到版本控制系统（已添加到.gitignore）
# 4. 限制文件权限：chmod 600 .env
# 5. 使用密钥管理服务（如HashiCorp Vault、AWS Secrets Manager）存储生产环境密码
# ----------------------------------------------------------------
