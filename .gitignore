# GCRF Library Management System - Git Ignore Rules
# Last Updated: 2025-11-01

# ============================================
# Environment Configuration Files (SECRETS)
# ============================================
# Critical: Never commit real secrets to Git!

# Environment files with secrets
.env
.env.local
.env.dev
.env.staging
.env.prod
.env.*.local

# Docker secrets
docker-secrets/
secrets/

# Kubernetes secrets (if applicable)
k8s-secrets/
*.secret.yaml
*-secret.yaml

# Keep templates only
!.env.example
!.env.template

