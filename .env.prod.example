# ============================================
# GCRF Library Management System
# Production Environment Configuration Template
# ============================================
# IMPORTANT: Copy this file to .env.prod and replace ALL values
# DO NOT commit .env.prod to version control!
# ============================================

# ============================================
# Nacos Service Discovery & Configuration
# ============================================
# Address of Nacos server (host:port or service name in Docker)
NACOS_SERVER_ADDR=nacos:8848

# Nacos authentication credentials
# SECURITY: Change these from defaults!
NACOS_USERNAME=prod_nacos_user
NACOS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Nacos namespace for environment isolation
NACOS_NAMESPACE=production

# Nacos group for service grouping
NACOS_GROUP=GCRF_LIBRARY

# ============================================
# JWT Token Configuration
# ============================================
# JWT secret key for token signing (MUST be 64+ characters for HS512)
# CRITICAL: Generate a strong random secret!
# Generate with: openssl rand -base64 96
JWT_SECRET=REPLACE_WITH_RANDOM_128_CHARACTER_SECRET_MINIMUM_64_CHARS_REQUIRED_FOR_HS512_ALGORITHM

# Token expiration in milliseconds (default: 24 hours = 86400000)
JWT_EXPIRATION=86400000

# Refresh token expiration (default: 7 days = 604800000)
JWT_REFRESH_EXPIRATION=604800000

# Token issuer identifier
JWT_ISSUER=GCRF-Library-System

# ============================================
# PostgreSQL Database Configuration
# ============================================
# Database host (use service name in Docker: postgres)
DB_HOST=postgres

# Database port
DB_PORT=5432

# Database name
DB_NAME=gcrf_auth

# Database credentials
# SECURITY: Use a dedicated database user with minimal privileges!
DB_USERNAME=gcrf_prod_user
DB_PASSWORD=REPLACE_WITH_STRONG_DATABASE_PASSWORD

# Full database URL (optional, overrides above if set)
# Note: sslmode=require enforces SSL connection for production security
# DB_URL=jdbc:postgresql://postgres:5432/gcrf_auth?sslmode=require&prepareThreshold=0

# ============================================
# Redis Cache Configuration
# ============================================
# Redis host (use service name in Docker: redis)
REDIS_HOST=redis

# Redis port
REDIS_PORT=6379

# Redis password
# SECURITY: Always set a password for Redis in production!
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD

# Redis database number (0-15)
REDIS_DATABASE=0

# ============================================
# CORS Configuration
# ============================================
# Allowed origins for Cross-Origin Resource Sharing
# SECURITY: Be specific! Use exact domains, not wildcards!
# Examples:
#   Single domain: https://library.gcrf.com
#   Multiple domains: https://library.gcrf.com,https://admin.gcrf.com
#   Subdomain pattern: https://*.gcrf.com
CORS_ALLOWED_ORIGINS=https://library.gcrf.com,https://admin.gcrf.com

# ============================================
# Server Configuration
# ============================================
# Gateway service port
SERVER_PORT=8080

# Management/Actuator port (for health checks, metrics)
MANAGEMENT_PORT=8090

# Application version (for service metadata)
APP_VERSION=1.0.0

# ============================================
# Thread Pool Configuration
# ============================================
# Core thread pool size
THREAD_POOL_CORE_SIZE=10

# Maximum thread pool size
THREAD_POOL_MAX_SIZE=50

# Thread pool queue capacity
THREAD_POOL_QUEUE_CAPACITY=100

# Scheduler pool size
SCHEDULER_POOL_SIZE=5

# ============================================
# Gateway Configuration
# ============================================
# Connection timeout in milliseconds
GATEWAY_CONNECT_TIMEOUT=10000

# Response timeout (supports duration format: 30s, 1m, etc.)
GATEWAY_RESPONSE_TIMEOUT=30s

# ============================================
# Rate Limiting Configuration
# ============================================
# Book service rate limits (requests per second)
BOOK_SERVICE_RATE_LIMIT=100
BOOK_SERVICE_BURST_CAPACITY=200

# Reader service rate limits
READER_SERVICE_RATE_LIMIT=100
READER_SERVICE_BURST_CAPACITY=200

# Circulation service rate limits
CIRCULATION_SERVICE_RATE_LIMIT=50
CIRCULATION_SERVICE_BURST_CAPACITY=100

# ============================================
# Netty Configuration (for WebFlux)
# ============================================
# Maximum connections in connection pool
NETTY_MAX_CONNECTIONS=500

# Maximum idle time for connections
NETTY_MAX_IDLE_TIME=30s

# Maximum lifetime for connections
NETTY_MAX_LIFE_TIME=60s

# Connection timeout
NETTY_CONNECT_TIMEOUT=10000

# Read timeout
NETTY_READ_TIMEOUT=30000

# Write timeout
NETTY_WRITE_TIMEOUT=30000

# ============================================
# Logging Configuration
# ============================================
# Log file path
LOG_PATH=/var/log/gcrf

# ============================================
# Additional Production Settings
# ============================================
# Enable production optimizations
SPRING_PROFILES_ACTIVE=prod

# Server IO threads
SERVER_IO_THREADS=8

# Server worker threads
SERVER_WORKER_THREADS=200

# ============================================
# Security Notes
# ============================================
# 1. Generate strong random passwords (minimum 32 characters)
#    Example: openssl rand -base64 32
#
# 2. JWT_SECRET must be at least 64 characters for HS512 algorithm
#    Generate with: openssl rand -base64 96
#
# 3. Database connection should use SSL (sslmode=require in URL)
#
# 4. Redis should always have a password in production
#
# 5. CORS origins should be specific domains, never use "*"
#
# 6. Store this file in a secure location (AWS Secrets Manager,
#    HashiCorp Vault, Azure Key Vault, etc.)
#
# 7. Never commit .env.prod to version control!
#    Add to .gitignore: .env.prod
#
# 8. Rotate all secrets every 90 days minimum
#
# 9. Use different credentials for each environment (dev/staging/prod)
#
# 10. Validate configuration before deployment:
#     ./deployment/scripts/validate-config.sh prod
# ============================================
